{
  "name": "archmap",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "archmap",
      "version": "0.1.0",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=22"
      }
    },
    "node_modules/@archmap/render": {
      "resolved": "packages/render",
      "link": true
    },
    "node_modules/@archmap/schema": {
      "resolved": "packages/schema",
      "link": true
    },
    "node_modules/@archmap/validate": {
      "resolved": "packages/validate",
      "link": true
    },
    "packages/render": {
      "name": "@archmap/render",
      "version": "0.1.0",
      "dependencies": {
        "@archmap/schema": "*",
        "@archmap/validate": "*"
      },
      "bin": {
        "archmap-render": "render.mjs"
      },
      "engines": {
        "node": ">=22"
      }
    },
    "packages/schema": {
      "name": "@archmap/schema",
      "version": "0.1.0",
      "engines": {
        "node": ">=22"
      }
    },
    "packages/validate": {
      "name": "@archmap/validate",
      "version": "0.1.0",
      "dependencies": {
        "@archmap/schema": "*"
      },
      "bin": {
        "archmap-validate": "validate.mjs"
      },
      "engines": {
        "node": ">=22"
      }
    }
  }
}
